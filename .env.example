# ============================================
# Palworld Web Manager - Environment Variables
# ============================================

# Palworld Server REST API connection
# If running in the same Docker network as palworld-server, use the service name
PALWORLD_API_HOST=palworld-server
PALWORLD_API_PORT=8212
PALWORLD_API_USER=admin
PALWORLD_API_PASSWORD=your-admin-password

# Path to Palworld server's Saved directory on the host
# This should point to the same directory mounted in the palworld-server container
PALWORLD_SAVED_PATH=../compose/Saved

# Docker container name of the palworld game server
# Used for start/stop/restart via Docker socket
PALWORLD_CONTAINER_NAME=palworld-server

# Web UI port (frontend)
WEB_PORT=8080

# JWT Authentication
# Secret used to sign JWT tokens (defaults to PALWORLD_API_PASSWORD if not set)
# JWT_SECRET=your-secret-key

# Access token expiry — short-lived JWT (default: 30m)
JWT_EXPIRY=30m
# Refresh token expiry — long-lived, used to silently renew access tokens (default: 7d)
REFRESH_EXPIRY=7d
# Cookie maxAge — browser cookie lifetime, defaults to same as REFRESH_EXPIRY (default: 7d)
COOKIE_EXPIRY=7d
