# frontend/package-lock.json
# backend/bun.lock

# ============================================
# Environment / Secrets
# ============================================
.env
.env.local
.env.*.local

# ============================================
# Editor / IDE
# ============================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ============================================
# OS files
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Vite / Vue
# ============================================
*.local
.vite/

# ============================================
